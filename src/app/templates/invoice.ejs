<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice <%= transactionID %></title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 20px;
        color: #333;
      }
      h1 {
        text-align: center;
        margin-bottom: 20px;
      }
      .info,
      .details {
        margin-bottom: 20px;
      }
      .info div,
      .details div {
        margin: 4px 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
      }
      th,
      td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: left;
      }
      th {
        background: #f5f5f5;
      }
      .right {
        text-align: right;
      }
      .total {
        font-weight: bold;
        font-size: 18px;
        margin-top: 10px;
        text-align: right;
      }
      .print-btn {
        margin-top: 20px;
        text-align: center;
      }
      .print-btn button {
        padding: 8px 16px;
      }
      @media print {
        .print-btn {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <h1>INVOICE</h1>

    <div class="info">
      <div><strong>Transaction ID:</strong> <%= transactionID %></div>
      <div>
        <strong>Booking Date:</strong> <%= new
        Date(bookingDate).toLocaleDateString() %>
      </div>
    </div>

    <div class="details">
      <h3>Client Info</h3>
      <div><strong>Name:</strong> <%= clientName %></div>
      <div><strong>Email:</strong> <%= clientEmail %></div>
      <div><strong>Phone:</strong> <%= clientPhone %></div>
    </div>

    <div class="details">
      <h3>Tour Details</h3>
      <div><strong>Title:</strong> <%= tourTitle %></div>
      <div><strong>Guests:</strong> <%= guestCount %></div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Description</th>
          <th>Guests</th>
          <th class="right">Amount</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Tour Booking — <%= tourTitle %></td>
          <td><%= guestCount %></td>
          <td class="right"><%= bookingAmount.toFixed(2) %></td>
        </tr>
      </tbody>
    </table>

    <div class="total">Amount Due: <%= bookingAmount.toFixed(2) %></div>
  </body>
</html>
